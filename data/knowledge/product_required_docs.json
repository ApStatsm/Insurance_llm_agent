        "label": "암 진단비",
        "required_doc_groups": [
          {
            "label": "진단서",
            "any_of": ["진단서"],
            "reason": "진단명과 진단일 확인을 위해 필요할 수 있습니다."
          },
          {
            "label": "진단 확정 근거",
            "any_of": ["병리보고서"],
            "reason": "약관상 암 진단 확정 근거 확인을 위해 필요할 수 있습니다."
          },
          {
            "label": "진료비 영수증",
            "any_of": ["진료비 영수증"],
            "reason": "진료 및 청구 내역 확인을 위해 필요할 수 있습니다."
          }
        ],
        "key_fields": ["patient_name", "diagnosis_name", "diagnosis_date", "pathology_result"]
      }
    },
    "dental": {
      "prosthetic": {
        "label": "치아 보철 치료",
        "required_doc_groups": [
          {
            "label": "진료비 영수증",
            "any_of": ["진료비 영수증"],
            "reason": "치료비 결제 내역 확인을 위해 필요할 수 있습니다."
          },
          {
            "label": "치과 진료기록",
            "any_of": ["진료확인서", "진단서"],
            "reason": "치료 내용과 치료일 확인을 위해 필요할 수 있습니다."
          },
          {
            "label": "영상 또는 치료 확인 자료",
            "any_of": ["엑스레이", "치료 전후 사진"],
            "reason": "보철 치료 상태 확인을 위해 필요할 수 있습니다."
          }
        ],
        "key_fields": ["patient_name", "hospital_name", "treatment_date", "treatment_type", "total_amount"]
      }
    }
  },
