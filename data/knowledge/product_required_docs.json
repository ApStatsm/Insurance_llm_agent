{
  "claim_scenarios": {
    "auto": {
      "flood": {
        "label": "자동차 침수 사고",
        "required_doc_groups": [
          {
            "label": "사고 확인 서류",
            "any_of": ["사고사실확인서"],
            "reason": "사고 경위와 발생일 확인을 위해 필요할 수 있습니다."
          },
          {
            "label": "수리비 확인 서류",
            "any_of": ["수리견적서"],
            "reason": "차량 손상 범위와 수리금액 확인을 위해 필요할 수 있습니다."
          },
          {
            "label": "차량 확인 서류",
            "any_of": ["차량등록증"],
            "reason": "가입 차량과 제출 서류의 차량 일치 여부 확인을 위해 필요할 수 있습니다."
          },
          {
            "label": "손상 확인 자료",
            "any_of": ["침수 사진"],
            "reason": "침수 또는 파손 상태 확인을 위해 필요할 수 있습니다."
          }
        ],
        "key_fields": ["vehicle_number", "accident_date", "repair_amount", "damage_type"]
      }
    },
    "indemnity": {
      "manual_therapy": {
        "label": "실손 도수치료",
        "required_doc_groups": [
          {
            "label": "진료비 영수증",
            "any_of": ["진료비 영수증"],
            "reason": "실제 결제 금액 확인을 위해 필요할 수 있습니다."
          },
          {
            "label": "진료비 세부내역",
            "any_of": ["진료비 세부내역서"],
            "reason": "도수치료 등 비급여 항목 확인을 위해 필요할 수 있습니다."
          },
          {
            "label": "진단 또는 진료 확인 서류",
            "any_of": ["진단서", "진료확인서"],
            "reason": "치료 목적과 진료 내용을 확인하기 위해 필요할 수 있습니다."
          }
        ],
        "key_fields": ["patient_name", "hospital_name", "treatment_date", "total_amount", "treatment_type"]
      }
    },
    "cancer": {
